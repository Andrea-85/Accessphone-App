generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model productos {
  id                Int              @id @default(autoincrement())
  nombre            String           @db.VarChar(100)
  precio            Decimal          @db.Decimal(12, 2)
  costo             Decimal
  stock             Int
  estado            String?          @db.VarChar(20)
  imei              String?          @unique @db.VarChar(20)
  descripcion_estado String?
  
  // Relación con Categoría
  categoriaId       Int?
  imagen             String?
  categoria          categorias?      @relation(fields: [categoriaId], references: [id])
  
  // Relación con Subcategoría (NUEVO)
  subcategoriaId    Int?
  subcategoria      Subcategoria?    @relation(fields: [subcategoriaId], references: [id])

  detalles          detalles_venta[] 
}

model categorias {
  id             Int            @id @default(autoincrement())
  nombre         String         @unique @db.VarChar(50)
  productos      productos[]
  subcategorias  Subcategoria[]
}

model Subcategoria {
  id          Int       @id @default(autoincrement())
  nombre      String    // Ejemplo: "Cerámico", "Blindado"
  categoriaId Int
  
  categoria   categorias @relation(fields: [categoriaId], references: [id])
  productos   productos[] 
}

model clientes {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(100)
  telefono   String?  @db.VarChar(20)
  email      String?  @unique @db.VarChar(100)
  direccion  String?
  cedula     String   @unique @db.VarChar(20)
  ventas     ventas[] 
}

model ventas {
  id         Int      @id @default(autoincrement())
  fecha      DateTime @default(now())
  clienteId  Int
  total      Decimal  @db.Decimal(12, 2)
  
  cliente    clientes @relation(fields: [clienteId], references: [id])
  detalles   detalles_venta[] 
}

model detalles_venta {
  id              Int      @id @default(autoincrement())
  ventaId         Int
  productoId      Int
  cantidad        Int
  precio_unitario Decimal @db.Decimal(12, 2)

  venta           ventas    @relation(fields: [ventaId], references: [id])
  producto        productos @relation(fields: [productoId], references: [id])
}

model usuarios {
  id       Int    @id @default(autoincrement())
  nombre   String
  email    String @unique
  password String
  rol      String @default("vendedor")
}